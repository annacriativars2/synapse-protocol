# ==============================================
# SYNAPSE — Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Workspace ---
# Base directory where SYNAPSE session folders will be created
SYNAPSE_WORKSPACE=/path/to/your/workspace

# --- Telegram notifications (optional) ---
# Create a bot via @BotFather and get your chat ID
TELEGRAM_BOT_TOKEN=123456:ABC-DEFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# --- Email notifications (optional) ---
# Requires a Gmail account with 2FA and an App Password
# https://myaccount.google.com/apppasswords
NEXA_GMAIL_ADDRESS=your_ai@gmail.com
NEXA_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SUPERVISOR_EMAIL=you@example.com

# --- Bridge (Agent B side) ---
# Path to the Claude Code CLI binary (default: claude, if in PATH)
CLAUDE_BIN=claude
