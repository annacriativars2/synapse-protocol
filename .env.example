# ==============================================
# SYNAPSE — Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Redis ---
SYNAPSE_REDIS_HOST=localhost
SYNAPSE_REDIS_PORT=6379

# --- Participant names (display) ---
SYNAPSE_AGENT_A_NAME="Agent A"
SYNAPSE_AGENT_B_NAME="Agent B"
SYNAPSE_SUPERVISOR_NAME="Supervisor"

# --- Workspace ---
# Base directory where SYNAPSE session folders will be created
SYNAPSE_SESSIONS_DIR=./synapse_sessions
SYNAPSE_ARCHIVES_DIR=./synapse_archives

# --- Bridge (Agent B side) ---
# Path to the Agent B CLI binary (default: claude, if in PATH)
SYNAPSE_AGENT_B_BIN=claude
SYNAPSE_BRIDGE_TIMEOUT=1800
SYNAPSE_WORKING_DIR=.

# --- Email notifications (optional) ---
# Requires an SMTP account (Gmail with App Password recommended)
# https://myaccount.google.com/apppasswords
SYNAPSE_SMTP_FROM=your_ai@gmail.com
SYNAPSE_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SYNAPSE_SUPERVISOR_EMAIL=you@example.com
